# Runtime
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///data/jobseeking_agent.db

# Browser automation
BROWSER_HEADLESS=false
BROWSER_SLOW_MO_MS=100
USER_AGENT=JobSeekingAgent/0.1 (+https://github.com/your-username/JobSeekingAgent)

# Scraping behavior
REQUEST_TIMEOUT_SECONDS=30
CRAWL_DELAY_SECONDS=3
MAX_JOBS_PER_SOURCE=50

# Candidate profile
CANDIDATE_NAME=
CANDIDATE_EMAIL=
CANDIDATE_PHONE=
CANDIDATE_LOCATION=
RESUME_PATH=./resumes/default.pdf
COVER_LETTER_TEMPLATE_PATH=./cover_letters/default.md

# Job preferences
TARGET_TITLES=Software Engineer,Backend Engineer,Data Engineer
TARGET_LOCATIONS=Remote,Sydney,Melbourne
MIN_SALARY=
WORK_AUTHORIZATION=

# Optional job board credentials
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
SEEK_EMAIL=
SEEK_PASSWORD=
INDEED_EMAIL=
INDEED_PASSWORD=

# Optional AI provider settings
OPENAI_API_KEY=
OPENAI_MODEL=

# Notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
NOTIFICATION_EMAIL_TO=
