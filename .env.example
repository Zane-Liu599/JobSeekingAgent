# Runtime
APP_ENV=development
LOG_LEVEL=INFO

# Public web / Nginx gateway
WEB_HOST_PORT=8080
WEB_CONTAINER_PORT=80
VITE_API_PROXY_TARGET=http://localhost:8080

# Private crawler backend
CRAWLER_HOST_PORT=8090
CRAWLER_CONTAINER_PORT=8000
CRAWLER_INTERNAL_URL=http://crawler-service:8000
CRAWLER_ADMIN_TOKEN=
CRAWLER_DEFAULT_KEYWORDS=software engineer,backend engineer,full stack developer
CRAWLER_DEFAULT_LOCATIONS=Sydney,Melbourne,Remote
CRAWLER_DEFAULT_PLATFORMS=seek,linkedin,indeed
CRAWLER_PROVIDER=auto
CRAWLER_OFFICIAL_APPLY_ONLY=true
CRAWLER_ALLOW_SEARCH_DISCOVERY=true
JOBSPY_RESULTS_WANTED=25
JOBSPY_HOURS_OLD=168
JOBSPY_COUNTRY_INDEED=Australia
JOBSPY_LINKEDIN_FETCH_DESCRIPTION=true
JOBSPY_PROXIES=

# Identity service
JWT_SECRET=change-this-in-production
APP_PUBLIC_URL=http://localhost:8080
# Required for registration email verification. For Gmail, use smtp.gmail.com
# with an app password, not your normal account password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@jobseeking-agent.local
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# MySQL 8: identity and communication data
MYSQL_HOST_PORT=3307
MYSQL_CONTAINER_PORT=3306
MYSQL_ROOT_PASSWORD=jobseeking-root
MYSQL_USER=jobseeking
MYSQL_PASSWORD=jobseeking
MYSQL_IDENTITY_DATABASE=identity
MYSQL_COMMUNICATION_DATABASE=communication

# PostgreSQL 17 + pgvector: AI vector data
POSTGRES_HOST_PORT=5432
POSTGRES_CONTAINER_PORT=5432
POSTGRES_USER=jobseeking
POSTGRES_PASSWORD=jobseeking
POSTGRES_AI_DATABASE=ai

# Redis + Celery
REDIS_HOST_PORT=6379
REDIS_CONTAINER_PORT=6379
REDIS_URL=redis://redis:6379/0

# MinIO object storage
MINIO_API_HOST_PORT=9000
MINIO_API_CONTAINER_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
MINIO_CONSOLE_CONTAINER_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET_DOCUMENTS=documents

# AI provider
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Legacy job automation storage used by ai-service during migration
DATABASE_URL=sqlite:////app/data/jobseeking_agent.db

# Browser automation / job crawling defaults
BROWSER_HEADLESS=true
BROWSER_SLOW_MO_MS=100
BROWSER_STORAGE_DIR=./data/browser-states
USER_AGENT=JobSeekingAgent/0.1 (+https://github.com/your-username/JobSeekingAgent)
REQUEST_TIMEOUT_SECONDS=30
CRAWL_DELAY_SECONDS=3
MAX_JOBS_PER_SOURCE=50
MAX_SEARCH_RESULTS=20

# Candidate profile defaults
CANDIDATE_NAME=
CANDIDATE_EMAIL=
CANDIDATE_PHONE=
CANDIDATE_LOCATION=
